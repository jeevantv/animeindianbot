{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "animeindianbot",
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "graphql.anilist.co"
      ]
    },
    "redis": true
  },
  "scheduler": {
    "tasks": {
      "example-1-min-scheduler": {
        "endpoint": "/internal/scheduler/example-1-min-scheduler",
        "cron": "*/1 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./tools/build.ts --watch",
    "build": "node --experimental-strip-types ./tools/build.ts --minify"
  },
  "dev": {
    "subreddit": "animeindianbot_dev"
  }
}