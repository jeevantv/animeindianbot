{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "animeindianbot",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "inline": true,
        "height": "regular"
      },
      "episode-schedule-dashbord": {
        "entry": "episode-schedule-dashbord.html",
        "height": "tall"
      },
      "polls-splash": {
        "entry": "polls-splash.html",
        "height": "regular"
      },
      "poll-options": {
        "entry": "poll-options.html",
        "height": "tall"
      },
      "polls-v2": {
        "entry": "polls-v2.html",
        "inline": true,
        "height": "regular"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "graphql.anilist.co",
        "youtube.com"
      ]
    },
    "redis": true,
    "reddit": true
  },
  "scheduler": {
    "tasks": {
      "daily-schedule-job": {
        "endpoint": "/internal/scheduler/daily-schedule-job",
        "cron": "0 0 * * *"
      },
      "post-episode-schedule": {
        "endpoint": "/internal/scheduler/post-episode-schedule"
      },
      "muse-india-yt-rss-post": {
        "endpoint": "/internal/scheduler/muse-india-yt-rss-post",
        "cron": "*/15 * * * *"
      }
    }
  },
  "settings": {
    "subreddit": {
      "episodeDiscussionFlairId": {
        "type": "string",
        "label": "Episode Discussion Flair ID It is required for this bot to run",
        "defaultValue": ""
      },
      "DealyedByMins": {
        "type": "string",
        "label": "Dealy episode Discussion thread in mins",
        "defaultValue": "120"
      },
      "enableMuseIndiaDicussion": {
        "type": "boolean",
        "label": "Enable Muse India Youtube channel Episode Discussion thread",
        "defaultValue": false
      },
      "enableSocialLinks": {
        "type": "boolean",
        "defaultValue": false,
        "label": "Enable social links in post body for Episode Discussion thread"
      },
      "discordInviteLink": {
        "type": "string",
        "defaultValue": "",
        "label": "Discord Invite Link"
      },
      "instagramLink": {
        "type": "string",
        "defaultValue": "",
        "label": "Instagram Link"
      },
      "youtubeChannelLink": {
        "type": "string",
        "defaultValue": "",
        "label": "Youtube Channel Link"
      },
      "xLink": {
        "type": "string",
        "defaultValue": "",
        "label": "x Link"
      }
    }
  },
  "menu": {
    "items": [
      {
        "label": "Episode Schedule Dashbord",
        "location": "subreddit",
        "description": "Check episode that are releasing today",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-splash-post"
      },
      {
        "label": "Create Poll Post",
        "location": "subreddit",
        "description": "Create a poll post for your subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-poll-postForm"
      },
      {
        "label": "Create Poll Post v2",
        "location": "subreddit",
        "description": "Create an inline poll post (v2) for your subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-poll-v2-postForm"
      }
    ]
  },
  "forms": {
    "pollForm": "/internal/form/pollForm",
    "poll-v2-Form": "/internal/form/poll-v2-Form"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "animeindianbot_dev"
  }
}