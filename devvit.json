{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "animeindianbot",
  "server": {
    "dir": "dist/server",
    "entry": "index.js"
  },
  "permissions": {
    "http": {
      "enable": true,
      "domains": [
        "graphql.anilist.co",
        "youtube.com"
      ]
    },
    "redis": true,
    "reddit": true
  },
  "settings": {
    "subreddit": {
      "episodeDiscussionFlairId": {
        "type": "string",
        "label": "Episode Discussion Flair ID It is required for this bot to run",
        "defaultValue": ""
      },
      "enableSocialLinks": {
        "type": "boolean",
        "defaultValue": false,
        "label": "Enable social links in post body for Episode Discussion"
      },
      "discordInviteLink": {
        "type": "string",
        "defaultValue": "",
        "label": "Discord Invite Link"
      },
      "instagramLink": {
        "type": "string",
        "defaultValue": "",
        "label": "Instagram Link"
      },
      "youtubeChannelLink": {
        "type": "string",
        "defaultValue": "",
        "label": "Youtube Channel Link"
      }
    }
  },
  "scheduler": {
    "tasks": {
      "daily-schedule-job": {
        "endpoint": "/internal/scheduler/daily-schedule-job",
        "cron": "0 0 * * *"
      },
      "post-episode-alarm": {
        "endpoint": "/internal/scheduler/post-episode-alarm"
      },
      "muse-india-yt-rss-post": {
        "endpoint": "/internal/scheduler/muse-india-yt-rss-post",
        "cron": "*/15 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "node --experimental-strip-types ./tools/build.ts --watch",
    "build": "node --experimental-strip-types ./tools/build.ts --minify"
  },
  "dev": {
    "subreddit": "animeindianbot_dev"
  }
}